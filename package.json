{
  "name": "hubzz-web",
  "version": "1.0.0",
  "description": " ",
  "author": " ",
  "private": true,
  "scripts": {
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "analyze": "nuxt build --analyze",
    "svg": "vsvg -s ./static/svg -t ./assets/svg",
    "lint": "eslint . --ignore-pattern 'node_modules/'"
  },
  "dependencies": {
    "@nuxtjs/auth": "^4.5.3",
    "@nuxtjs/axios": "^5.3.6",
    "cookie-universal-nuxt": "^2.0.14",
    "cross-env": "^5.2.0",
    "dotenv": "^7.0.0",
    "eslint-plugin-nuxt": "^0.4.3",
    "eslint-plugin-vue": "^5.2.2",
    "lodash.debounce": "^4.0.8",
    "moment": "^2.24.0",
    "nuxt": "^2.7.1",
    "socket.io-client": "^2.2.0",
    "validator": "^10.11.0",
    "vue-clickaway": "^2.2.2",
    "vue-svgicon": "^3.2.4",
    "vue2-google-maps": "^0.10.6"
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "@commitlint/cli": "^7.6.1",
    "@commitlint/config-conventional": "^7.6.0",
    "autoprefixer": "^8.6.4",
    "commitizen": "^3.1.1",
    "cz-conventional-changelog": "^2.1.0",
    "eslint": "^5.14.1",
    "eslint-plugin-nuxt": "^0.4.3",
    "eslint-plugin-vue": "^5.2.2",
    "husky": "^2.3.0",
    "lint-staged": "^8.1.6",
    "nodemon": "^1.18.9",
    "tailwindcss": "^0.7.0"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add",
      "eslint"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
